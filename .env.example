# === Ollama Configuration ===
OLLAMA_BASE_URL=http://localhost:11434
LLM_MODEL=llama3
EMBEDDING_MODEL=nomic-embed-text

# === Qdrant Settings (Vector DB) ===
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=enterprise_docs

# === Neo4j Settings (GraphRAG) ===
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# === Chunking Parameters ===
CHUNK_SIZE=1000
CHUNK_OVERLAP=150

# === Retrieval ===
TOP_K=5
HYBRID_ALPHA=0.5

# === Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === Logging ===
LOG_DIR=./logs
